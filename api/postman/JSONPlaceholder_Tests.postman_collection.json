    {
      "name": "GET comments for postId 1",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response is an array\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(Array.isArray(jsonData)).to.be.true;\r",
              "});\r",
              "\r",
              "pm.test(\"First comment has all required fields\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    if (jsonData.length > 0) {\r",
              "        pm.expect(jsonData[0]).to.have.property('postId');\r",
              "        pm.expect(jsonData[0]).to.have.property('id');\r",
              "        pm.expect(jsonData[0]).to.have.property('name');\r",
              "        pm.expect(jsonData[0]).to.have.property('email');\r",
              "        pm.expect(jsonData[0]).to.have.property('body');\r",
              "    }\r",
              "});\r",
              "\r",
              "pm.test(\"All comments have postId === 1\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    jsonData.forEach(comment => {\r",
              "        pm.expect(comment.postId).to.equal(1);\r",
              "    });\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
